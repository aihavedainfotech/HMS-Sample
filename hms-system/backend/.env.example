# Database Configuration (PostgreSQL only - single database)
# Use DATABASE_URL for the backend. Optional: DB_* for building URL elsewhere.
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/hospital_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hospital_db
DB_USER=postgres
DB_PASSWORD=your_password

# JWT Secret
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
SECRET_KEY=your-super-secret-key-change-in-production

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# File Upload
UPLOAD_FOLDER=/tmp/hms_uploads

# Environment
FLASK_ENV=development
FLASK_DEBUG=1

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# WhatsApp Integration (Meta Business - get from developers.facebook.com WhatsApp > API testing)
WHATSAPP_API_URL=https://graph.facebook.com/v22.0
WHATSAPP_PHONE_NUMBER_ID=1033955206448310
WHATSAPP_ACCESS_TOKEN=your_access_token_here
BUSINESS_PHONE_NUMBER=+91XXXXXXXXXX
# Real-time: 1 = send notification immediately when operation is performed; 0 = background queue only
WHATSAPP_SEND_IMMEDIATE=1

# Registration Fee
REGISTRATION_FEE=50.0

