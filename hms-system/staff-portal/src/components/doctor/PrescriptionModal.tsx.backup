import { useState, useEffect, useRef } from 'react';
import { useForm } from 'react-hook-form';
import {
    Dialog,
    DialogContent,
    DialogHeader,
    DialogTitle,
    DialogFooter,
} from '@/components/ui/dialog';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';

import { Trash2, Save, Search, Loader2, CheckCircle2 } from 'lucide-react';
import { toast } from 'sonner';

// Use relative /api so Vite proxy is used (avoids CORS and stuck "Saving...")
const PRESCRIPTIONS_URL = '/api/prescriptions';
const INVENTORY_URL = '/api/pharmacy/inventory';

interface Medicine {
    medicine_id?: string;
    id?: string;
    generic_name: string;
    brand_name: string;
    strength: string;
    current_stock: number;
    unit_price?: number;
    expiry_date?: string;
    category?: string;
    dosage_form?: string;
    manufacturer?: string;
    packaging?: string;
}

interface SelectedMedicine {
    medicine: Medicine;
    quantity: number;
    frequency: string;
    duration: string;
    instructions: string;
}

interface PrescriptionModalProps {
    patientId: string;
    appointmentId?: string | null;
    open: boolean;
    onOpenChange: (open: boolean) => void;
    onSuccess: () => void;
}

export function PrescriptionModal({
    patientId,
    appointmentId,
    open,
    onOpenChange,
    onSuccess,
}: PrescriptionModalProps) {
    const [loading, setLoading] = useState(false);
    const [pharmacyMedicines, setPharmacyMedicines] = useState<Medicine[]>([]);
    const [loadingMedicines, setLoadingMedicines] = useState(false);
    const [selectedList, setSelectedList] = useState<SelectedMedicine[]>([]);
    const [searchValue, setSearchValue] = useState('');
    const [searchResults, setSearchResults] = useState<Medicine[]>([]);
    const [showDropdown, setShowDropdown] = useState(false);
    const dropdownRef = useRef<HTMLDivElement>(null);

    const { register, handleSubmit, reset, setValue, watch } = useForm({
        defaultValues: {
            diagnosis: '',
            chief_complaint: '',
        }
    });

    const diagnosis = watch('diagnosis');
    const chief_complaint = watch('chief_complaint');

    useEffect(() => {
        if (open) {
            fetchPharmacyMedicines();
            setSelectedList([]);
            setSearchValue('');
            setSearchResults([]);
        }
    }, [open]);

    useEffect(() => {
        if (!searchValue.trim()) {
            setSearchResults([]);
            setShowDropdown(false);
            return;
        }
        const term = searchValue.toLowerCase();
        const filtered = pharmacyMedicines.filter(med =>
            (med.generic_name?.toLowerCase().includes(term)) ||
            (med.brand_name?.toLowerCase().includes(term)) ||
            (med.dosage_form?.toLowerCase().includes(term)) ||
            (med.category?.toLowerCase().includes(term))
        ).slice(0, 10);
        setSearchResults(filtered);
        setShowDropdown(filtered.length > 0);
    }, [searchValue, pharmacyMedicines]);

    useEffect(() => {
        const handleClickOutside = (e: MouseEvent) => {
            if (dropdownRef.current && !dropdownRef.current.contains(e.target as Node)) {
                setShowDropdown(false);
            }
        };
        document.addEventListener('mousedown', handleClickOutside);
        return () => document.removeEventListener('mousedown', handleClickOutside);
    }, []);

    const fetchPharmacyMedicines = async () => {
        setLoadingMedicines(true);
        try {
            const token = localStorage.getItem('hms_staff_token');
            const response = await fetch(INVENTORY_URL, {
                headers: { Authorization: `Bearer ${token}` },
            });
            if (response.ok) {
                const data: Medicine[] = await response.json();
                const today = new Date();
                const threeMonths = new Date(today.getTime() + 90 * 24 * 60 * 60 * 1000);
                const valid = data.filter(med => {
                    if (!med.generic_name || !med.brand_name) return false;
                    const stock = med.current_stock ?? 0;
                    const expiry = med.expiry_date ? new Date(med.expiry_date) : null;
                    return stock > 0 && (!expiry || (expiry > today && expiry > threeMonths));
                });
                if (valid.length === 0 && data.length > 0) {
                    setPharmacyMedicines(data.filter(m => (m.current_stock ?? 0) > 0 && m.generic_name && m.brand_name));
                } else {
                    setPharmacyMedicines(valid);
                }
            }
        } catch (e) {
            console.error(e);
            toast.error('Failed to load pharmacy inventory');
        } finally {
            setLoadingMedicines(false);
        }
    };

    const addMedicine = (medicine: Medicine) => {
        if (selectedList.some(s => (s.medicine.medicine_id || s.medicine.id) === (medicine.medicine_id || medicine.id))) {
            toast.info('Medicine already in list');
            return;
        }
        setSelectedList(prev => [...prev, {
            medicine,
            quantity: 1,
            frequency: 'BD',
            duration: '5 days',
            instructions: '',
        }]);
        setSearchValue('');
        setSearchResults([]);
        setShowDropdown(false);
        toast.success(`${medicine.generic_name} added to list`);
    };

    const updateSelected = (index: number, field: keyof Omit<SelectedMedicine, 'medicine'>, value: string | number) => {
        setSelectedList(prev => prev.map((item, i) => i === index ? { ...item, [field]: value } : item));
    };

    const removeMedicine = (index: number) => {
        setSelectedList(prev => prev.filter((_, i) => i !== index));
    };

    const onSubmit = async (data: { diagnosis: string; chief_complaint: string }) => {
        if (selectedList.length === 0) {
            toast.error('Add at least one medicine');
            return;
        }
        for (let i = 0; i < selectedList.length; i++) {
            const item = selectedList[i];
            if (!item.quantity || item.quantity <= 0) {
                toast.error(`Medicine ${i + 1}: Enter valid quantity`);
                return;
            }
            if (item.quantity > (item.medicine.current_stock ?? 0)) {
                toast.error(`${item.medicine.generic_name}: Quantity exceeds stock (${item.medicine.current_stock} available)`);
                return;
            }
        }

        setLoading(true);
        const controller = new AbortController();
        const timeoutId = setTimeout(() => controller.abort(), 15000);

        try {
            const token = localStorage.getItem('hms_staff_token');
            const body = {
                patient_id: patientId,
                appointment_id: appointmentId || null,
                diagnosis: data.diagnosis,
                chief_complaint: data.chief_complaint,
                medicines: selectedList.map(item => ({
                    medicine_id: item.medicine.medicine_id || item.medicine.id,
                    medicine_name: item.medicine.generic_name,
                    generic_name: item.medicine.generic_name,
                    brand_name: item.medicine.brand_name,
                    strength: item.medicine.strength || '',
                    frequency: item.frequency,
                    duration: item.duration,
                    instructions: item.instructions,
                    quantity: Number(item.quantity),
                })),
            };

            const res = await fetch(PRESCRIPTIONS_URL, {
                method: 'POST',
                signal: controller.signal,
                headers: {
                    'Content-Type': 'application/json',
                    Authorization: `Bearer ${token}`,
                },
                body: JSON.stringify(body),
            });

            clearTimeout(timeoutId);

            if (res.ok) {
                const result = await res.json();
                toast.success(`Prescription ${result.prescription_id} created successfully`);
                reset();
                setSelectedList([]);
                setSearchValue('');
                onSuccess();
                onOpenChange(false);
            } else {
                const err = await res.json().catch(() => ({}));
                toast.error(err.error || err.message || `Failed to save (${res.status})`);
            }
        } catch (err: any) {
            clearTimeout(timeoutId);
            if (err.name === 'AbortError') {
                toast.error('Request timed out. Please try again.');
            } else {
                console.error(err);
                toast.error(err?.message || 'Failed to create prescription');
            }
        } finally {
            setLoading(false);
        }
    };

    return (
        <Dialog open={open} onOpenChange={onOpenChange}>
            <DialogContent className="max-w-4xl w-full max-h-[90vh] overflow-y-auto">
                <DialogHeader>
                    <DialogTitle className="text-2xl">New Prescription</DialogTitle>
                    {loadingMedicines && (
                        <div className="flex items-center gap-2 text-sm text-blue-600 mt-2">
                            <Loader2 className="h-4 w-4 animate-spin" />
                            Loading pharmacy medicines...
                        </div>
                    )}
                </DialogHeader>

                <form onSubmit={handleSubmit(onSubmit)} className="space-y-5">
                    <div className="grid grid-cols-2 gap-4">
                        <div className="space-y-2">
                            <Label className="font-semibold">Diagnosis</Label>
                            <Input {...register('diagnosis')} placeholder="e.g. Acute Bronchitis" required className="border-2" />
                        </div>
                        <div className="space-y-2">
                            <Label className="font-semibold">Chief Complaint</Label>
                            <Input {...register('chief_complaint')} placeholder="e.g. Cough for 3 days" className="border-2" />
                        </div>
                    </div>

                    <div className="border-t pt-4 space-y-3">
                        <h3 className="text-lg font-bold">Medicines from Pharmacy</h3>
                        <p className="text-sm text-green-600">Search and select medicines; they will be added to the list below.</p>

                        <div className="relative" ref={dropdownRef}>
                            <Label className="font-semibold flex items-center gap-2 mb-2">
                                <Search className="h-4 w-4" />
                                Add medicine
                            </Label>
                            <Input
                                type="text"
                                placeholder="Type medicine name..."
                                value={searchValue}
                                onChange={(e) => setSearchValue(e.target.value)}
                                onFocus={() => searchResults.length > 0 && setShowDropdown(true)}
                                className="border-2"
                            />
                            {showDropdown && searchResults.length > 0 && (
                                <div className="absolute top-full left-0 right-0 bg-white border-2 border-blue-200 rounded-lg shadow-lg z-50 mt-1 max-h-56 overflow-y-auto">
                                    {searchResults.map((med, idx) => (
                                        <button
                                            key={idx}
                                            type="button"
                                            className="w-full text-left px-4 py-3 hover:bg-blue-50 border-b last:border-b-0"
                                            onClick={() => addMedicine(med)}
                                        >
                                            <span className="font-semibold text-blue-700">{med.brand_name}</span>
                                            <span className="text-xs text-gray-600 ml-2">{med.generic_name} • {med.strength} • Stock: {med.current_stock}</span>
                                        </button>
                                    ))}
                                </div>
                            )}
                        </div>

                        {selectedList.length === 0 ? (
                            <div className="rounded-lg border-2 border-dashed border-gray-300 bg-gray-50/50 p-6 text-center text-gray-500 text-sm">
                                No medicines added yet. Search above and select to add.
                            </div>
                        ) : (
                            <div className="space-y-2">
                                <div className="flex items-center gap-2 text-sm font-medium text-gray-700">
                                    <CheckCircle2 className="h-4 w-4 text-green-600" />
                                    {selectedList.length} medicine(s) in list
                                </div>
                                <div className="rounded-lg border-2 border-gray-200 overflow-auto">
                                    <div className="w-full overflow-x-auto">
                                        <table className="w-full text-sm table-auto">
                                        <thead>
                                            <tr className="bg-gray-100 border-b">
                                                <th className="text-left p-2 font-semibold">Medicine</th>
                                                <th className="text-left p-2 font-semibold w-20">Qty</th>
                                                <th className="text-left p-2 font-semibold">Freq</th>
                                                <th className="text-left p-2 font-semibold">Duration</th>
                                                <th className="text-left p-2 font-semibold">Instructions</th>
                                                <th className="w-10"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {selectedList.map((item, index) => (
                                                <tr key={index} className="border-b last:border-b-0 hover:bg-blue-50/30">
                                                    <td className="p-2">
                                                        <span className="font-medium">{item.medicine.generic_name}</span>
                                                        <span className="text-gray-500 text-xs block">{item.medicine.brand_name} • {item.medicine.strength} (Stock: {item.medicine.current_stock})</span>
                                                    </td>
                                                        <td className="p-2">
                                                        <Input
                                                            type="number"
                                                            min={1}
                                                            max={item.medicine.current_stock}
                                                            value={item.quantity}
                                                                onChange={(e) => updateSelected(index, 'quantity', parseInt(e.target.value, 10) || 1)}
                                                                className="h-8 w-20 text-center border"
                                                        />
                                                    </td>
                                                    <td className="p-2">
                                                        <select
                                                            value={item.frequency}
                                                            onChange={(e) => updateSelected(index, 'frequency', e.target.value)}
                                                            className="h-8 rounded border border-gray-300 bg-white px-2 text-sm w-full"
                                                        >
                                                            <option value="OD">OD</option>
                                                            <option value="BD">BD</option>
                                                            <option value="TDS">TDS</option>
                                                            <option value="QID">QID</option>
                                                            <option value="SOS">SOS</option>
                                                        </select>
                                                    </td>
                                                    <td className="p-2">
                                                        <Input
                                                            value={item.duration}
                                                            onChange={(e) => updateSelected(index, 'duration', e.target.value)}
                                                            placeholder="5 days"
                                                            className="h-8 border text-sm"
                                                        />
                                                    </td>
                                                    <td className="p-2">
                                                        <Input
                                                            value={item.instructions}
                                                            onChange={(e) => updateSelected(index, 'instructions', e.target.value)}
                                                            placeholder="e.g. After food"
                                                            className="h-8 border text-sm"
                                                        />
                                                    </td>
                                                    <td className="p-2">
                                                        <Button
                                                            type="button"
                                                            variant="ghost"
                                                            size="sm"
                                                            onClick={() => removeMedicine(index)}
                                                            className="text-red-600 hover:bg-red-50 h-8 w-8 p-0"
                                                        >
                                                            <Trash2 className="h-4 w-4" />
                                                        </Button>
                                                    </td>
                                                </tr>
                                            ))}
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        )}
                    </div>

                    <DialogFooter className="border-t pt-4">
                        <div className="flex gap-3 w-full">
                            <Button type="button" variant="outline" onClick={() => onOpenChange(false)} className="border-2">
                                Cancel
                            </Button>
                            <Button
                                type="submit"
                                disabled={loading || loadingMedicines || selectedList.length === 0}
                                className="bg-blue-600 hover:bg-blue-700 text-white font-bold"
                            >
                                {loading ? (
                                    <>
                                        <Loader2 className="h-4 w-4 mr-2 animate-spin" />
                                        Saving...
                                    </>
                                ) : (
                                    <>
                                        <Save className="h-4 w-4 mr-2" />
                                        Create Prescription
                                    </>
                                )}
                            </Button>
                        </div>
                    </DialogFooter>
                </form>
            </DialogContent>
        </Dialog>
    );
}
